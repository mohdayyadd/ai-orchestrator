# Database
DATABASE_URL=postgresql+psycopg://orchestrator:orchestrator@postgres:5432/orchestrator

# Redis (checked by ao doctor; V1 execution is mostly synchronous)
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Paths — Docker defaults (override on host, e.g. ARTIFACTS_DIR=.agent_runs)
WORKSPACE_ROOT=/workspace
ARTIFACTS_DIR=/workspace/.agent_runs
TASKS_DIR=/workspace/tasks

# Set automatically in Docker image; on host leave unset or 0
# RUNNING_IN_DOCKER=0

# Discouraged: allow real CLI workers inside Docker (no auth mounts by default)
ALLOW_CLI_WORKERS_IN_DOCKER=false

# Real CLI workers — use on HOST with: uv run ao dispatch ... (subscription CLI auth stays on host)
ENABLE_CLAUDE_WORKER=false
CLAUDE_CODE_BIN=claude
# Optional extra argv for Claude Code CLI (non-secret), e.g. -p foo
CLAUDE_CODE_EXTRA_ARGS=
ENABLE_CODEX_WORKER=false
CODEX_BIN=codex
CODEX_EXTRA_ARGS=
ENABLE_CURSOR_WORKER=false
CURSOR_BIN=cursor

# Only if you understand the risk (dev only)
ALLOW_SKIP_CONFIRMATIONS=false

# ECC (optional)
ECC_ENABLED=false
ECC_SOURCE_URL=
ECC_CACHE_PATH=/workspace/ecc
ECC_ALLOW_HOOKS=false
ECC_ALLOW_NPX=false
ECC_INSTALL_DEFAULT_DRY_RUN=true

# Obsidian (optional)
OBSIDIAN_ENABLED=false
OBSIDIAN_VAULT_PATH=/workspace/obsidian-vault
OBSIDIAN_PROJECT_FOLDER=AI-Orchestrator
OBSIDIAN_WRITE_RUN_SUMMARIES=true
OBSIDIAN_WRITE_DECISIONS=true
OBSIDIAN_WRITE_LEARNINGS=true
OBSIDIAN_READ_PROJECT_NOTES=false
OBSIDIAN_MAX_CONTEXT_NOTES=5
OBSIDIAN_USE_URI=false
OBSIDIAN_USE_LOCAL_REST_API=false
OBSIDIAN_LOCAL_REST_API_URL=http://host.docker.internal:27123
OBSIDIAN_LOCAL_REST_API_KEY=

# Background worker (stub in V1 unless enabled)
ENABLE_REDIS_JOB_WORKER=false
